@model SistemaManejoBar.Models.CategoriaCoctel

@{
    ViewData["Title"] = "Create";
}

<h1>Agregar</h1>

<h4>Categoria de cocteles</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
