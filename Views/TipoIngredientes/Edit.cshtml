@model SistemaManejoBar.Models.TipoIngrediente
@{
    ViewData["Title"] = "Editar Tipo de Ingrediente";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h2 class="h5 mb-0">Editar Tipo de Ingrediente</h2>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="IdTipoIngrediente" />

                        <div class="mb-3">
                            <label asp-for="NombreTipoIngrediente" class="form-label">Nombre del Tipo de Ingrediente</label>
                            <input asp-for="NombreTipoIngrediente" class="form-control form-control-sm" required />
                            <span asp-validation-for="NombreTipoIngrediente" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary btn-sm">Volver</a>
                            <button type="submit" class="btn btn-primary btn-sm">Guardar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
