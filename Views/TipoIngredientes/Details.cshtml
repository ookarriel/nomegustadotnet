@model SistemaManejoBar.Models.TipoIngrediente
@{
    ViewData["Title"] = "Detalles de Tipo de Ingrediente";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h2 class="h5 mb-0">Detalles de Tipo de Ingrediente</h2>
                </div>
                <div class="card-body">
                    <dl class="row my-3">
                        <dt class="col-sm-4">ID:</dt>
                        <dd class="col-sm-8">@Model.IdTipoIngrediente</dd>
                        
                        <dt class="col-sm-4">Nombre:</dt>
                        <dd class="col-sm-8">@Model.NombreTipoIngrediente</dd>
                    </dl>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary btn-sm">Volver</a>
                        @if (User.IsInRole("Administrador"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.IdTipoIngrediente" class="btn btn-warning btn-sm">Editar</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
