@model SistemaManejoBar.Models.TipoIngrediente
@{
    ViewData["Title"] = "Eliminar Tipo de Ingrediente";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h2 class="h5 mb-0">¿Confirmar Eliminación?</h2>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        ¿Estás seguro de que deseas eliminar este tipo de ingrediente? Esta acción no se puede deshacer.
                    </div>
                    
                    <dl class="row my-3">
                        <dt class="col-sm-4">ID:</dt>
                        <dd class="col-sm-8">@Model.IdTipoIngrediente</dd>
                        
                        <dt class="col-sm-4">Nombre:</dt>
                        <dd class="col-sm-8">@Model.NombreTipoIngrediente</dd>
                    </dl>

                    <form asp-action="Delete" class="d-flex justify-content-between mt-4">
                        <input type="hidden" asp-for="IdTipoIngrediente" />
                        <a asp-action="Index" class="btn btn-secondary btn-sm">Cancelar</a>
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
