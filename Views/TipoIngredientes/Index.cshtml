@model IEnumerable<SistemaManejoBar.Models.TipoIngrediente>
@{
    ViewData["Title"] = "Tipos de Ingrediente";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h2">Tipos de Ingrediente</h1>
        <a asp-action="Create" class="btn btn-primary btn-sm">Agregar Tipo de Ingrediente</a>
    </div>

    <!-- Alertas de estado -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
            <strong>¡Atención!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <strong>¡Excelente!</strong> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Barra de búsqueda e interactividad -->
    <div class="card mb-4 bg-light">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-2 align-items-center">
                <input type="hidden" name="orden" value="@ViewData["OrdenActual"]" />
                <div class="col-md-5">
                    <div class="input-group">
                        <input type="text" name="buscar" value="@ViewData["BuscarActual"]" class="form-control form-control-sm" placeholder="Buscar por nombre..." />
                        <button type="submit" class="btn btn-primary btn-sm">Buscar</button>
                    </div>
                </div>
                <div class="col-md-4">
                    @if (!string.IsNullOrEmpty(ViewData["BuscarActual"]?.ToString()))
                    {
                        <a asp-action="Index" asp-route-orden="@ViewData["OrdenActual"]" class="btn btn-secondary btn-sm">Limpiar Búsqueda</a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Resumen de resultados -->
    <div class="mb-2 text-muted small">
        Mostrando @ViewData["RegistroInicio"]–@ViewData["RegistroFin"] de @ViewData["TotalRegistros"] resultados
    </div>

    <!-- Tabla interactiva -->
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>
                            <a asp-action="Index" asp-route-buscar="@ViewData["BuscarActual"]" asp-route-orden="@ViewData["NombreSortParam"]" class="text-white text-decoration-none">
                                Tipo de Ingrediente 
                                @(ViewData["OrdenActual"]?.ToString() == "nombre_desc" ? "▼" : (string.IsNullOrEmpty(ViewData["OrdenActual"]?.ToString()) ? "▲" : ""))
                            </a>
                        </th>
                        <th class="text-end px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="2" class="text-center py-4 text-muted">No se encontraron tipos de ingredientes.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@Html.DisplayFor(modelItem => item.NombreTipoIngrediente)</strong>
                                </td>
                                <td class="text-end px-4">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.IdTipoIngrediente" class="btn btn-info btn-sm text-white">Detalles</a>
                                        <a asp-action="Edit" asp-route-id="@item.IdTipoIngrediente" class="btn btn-warning btn-sm">Editar</a>
                                        <a asp-action="Delete" asp-route-id="@item.IdTipoIngrediente" class="btn btn-danger btn-sm">Eliminar</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (Convert.ToInt32(ViewData["TotalPaginas"]) > 1)
    {
        <div class="d-flex justify-content-center mt-4">
            <nav aria-label="Navegación de páginas">
                <ul class="pagination pagination-sm">
                    <li class="page-item @(Convert.ToInt32(ViewData["PaginaActual"]) == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["BuscarActual"]" asp-route-orden="@ViewData["OrdenActual"]" asp-route-pagina="@(Convert.ToInt32(ViewData["PaginaActual"]) - 1)">Anterior</a>
                    </li>
                    @for (int i = 1; i <= Convert.ToInt32(ViewData["TotalPaginas"]); i++)
                    {
                        <li class="page-item @(i == Convert.ToInt32(ViewData["PaginaActual"]) ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["BuscarActual"]" asp-route-orden="@ViewData["OrdenActual"]" asp-route-pagina="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Convert.ToInt32(ViewData["PaginaActual"]) == Convert.ToInt32(ViewData["TotalPaginas"]) ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["BuscarActual"]" asp-route-orden="@ViewData["OrdenActual"]" asp-route-pagina="@(Convert.ToInt32(ViewData["PaginaActual"]) + 1)">Siguiente</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
