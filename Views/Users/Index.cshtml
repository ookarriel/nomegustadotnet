@model IEnumerable<SistemaManejoBar.Models.UserListViewModel>
@{
    ViewData["Title"] = "Administración de Usuarios";
    var rolesDisponibles = ViewBag.RolesDisponibles as List<string> ?? new List<string>();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h2">Administración de Usuarios</h1>
        <a asp-action="Create" class="btn btn-primary btn-sm">Agregar Usuario</a>
    </div>

    <!-- Mensajes de estado -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <strong>¡Atención!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <strong>¡Excelente!</strong> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }

    <!-- Tabla de usuarios -->
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="px-4">Nombre Completo</th>
                        <th>Correo Electrónico</th>
                        <th>Rol Asignado</th>
                        <th>Estado</th>
                        <th class="text-end px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="px-4">
                                <strong>@user.NombreCompleto</strong>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                <!-- Formulario de cambio de rol -->
                                <form asp-action="CambiarRol" method="post" class="d-inline-flex align-items-center gap-1" onsubmit="return confirm('¿Estás seguro de que deseas cambiar el rol de este usuario?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <select name="nuevoRol" class="form-select form-select-sm rounded-2 py-1" style="width: auto;">
                                        @foreach (var rol in rolesDisponibles)
                                        {
                                            <!option value="@rol" @(user.Rol == rol ? "selected" : "")>@rol</!option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-primary py-1">Cambiar</button>
                                </form>
                            </td>
                            <td>
                                @if (user.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>
                            <td class="text-end px-4">
                                <div class="d-inline-flex gap-2">
                                    <!-- Botón Toggle de Estado Activo/Inactivo -->
                                    <form asp-action="ToggleActivo" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        @if (user.Activo)
                                        {
                                            <button type="submit" class="btn btn-warning btn-sm" onclick="return confirm('¿Estás seguro de desactivar a este usuario?');">
                                                Desactivar
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-success btn-sm">
                                                Activar
                                            </button>
                                        }
                                    </form>

                                    <!-- Botón Eliminar Usuario -->
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este usuario definitivamente? Esta acción no se puede deshacer.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
