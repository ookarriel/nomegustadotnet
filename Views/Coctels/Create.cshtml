@model SistemaManejoBar.Models.Coctel

@{
    ViewData["Title"] = "Create";
}

<h1>Añadir</h1>
<h4>Coctel</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="Foto" value="temporal" />
    
            <div class="form-group mb-3">
                <label class="control-label">Nombre del Cóctel</label>
                <input asp-for="NombreCoctel" class="form-control" />
                <span asp-validation-for="NombreCoctel" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Instrucciones de Preparación</label>
                <textarea asp-for="Instrucciones" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Instrucciones" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Precio de Venta</label>
                <input asp-for="PrecioVenta" class="form-control" type="number" />
                <span asp-validation-for="PrecioVenta" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Categoría</label>
                <select asp-for="IdCategoria" class="form-control" asp-items="ViewBag.IdCategoria"></select>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Cristalería</label>
                <select asp-for="IdCristaleria" class="form-control" asp-items="ViewBag.IdCristaleria"></select>
            </div>
            <div class="form-group mb-3">
                <label class="control-label fw-bold">Seleccionar Ingredientes</label>
                <select name="ingredientesSeleccionados" class="form-control" multiple size="6">
                    @if (ViewData["Ingredientes"] != null)
                    {
                        foreach (var ing in (IEnumerable<SistemaManejoBar.Models.Ingrediente>)ViewData["Ingredientes"])
                        {
                            <option value="@ing.IdIngrediente">@ing.NombreIngrediente</option>
                        }
                    }
                </select>
                <small class="form-text text-muted">Mantén presionado <strong>Ctrl</strong> (Windows) o <strong>Cmd</strong> (Mac) para seleccionar varios ingredientes.</small>
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Foto del Cóctel</label>
                <input type="file" name="archivo_foto" class="form-control" accept="image/*" />
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Crear Cóctel" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}