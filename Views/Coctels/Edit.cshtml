@model SistemaManejoBar.Models.Coctel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Coctel</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdCoctel" />

            <div class="form-group mb-3">
                <label class="control-label">Nombre del Cóctel</label>
                <input asp-for="NombreCoctel" class="form-control" />
                <span asp-validation-for="NombreCoctel" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Instrucciones de Preparación</label>
                <textarea asp-for="Instrucciones" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Instrucciones" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Precio de Venta</label>
                <input asp-for="PrecioVenta" class="form-control" type="number" />
                <span asp-validation-for="PrecioVenta" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Categoría</label>
                <select asp-for="IdCategoria" class="form-control" asp-items="ViewBag.IdCategoria"></select>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Cristalería</label>
                <select asp-for="IdCristaleria" class="form-control" asp-items="ViewBag.IdCristaleria"></select>
            </div>
            <div class="form-group mb-3">
                <label class="control-label fw-bold">Actualizar Ingredientes</label>
                <select name="ingredientesSeleccionados" class="form-control" multiple size="6">
                    @if (ViewData["Ingredientes"] != null)
                    {
                        var seleccionados = ViewData["IngredientesSeleccionados"] as List<int> ?? new List<int>();

                        foreach (var ing in (IEnumerable<SistemaManejoBar.Models.Ingrediente>)ViewData["Ingredientes"])
                        {
                            bool isSelected = seleccionados.Contains(ing.IdIngrediente);
                            <option value="@ing.IdIngrediente" selected="@(isSelected ? "selected" : null)">
                                @ing.NombreIngrediente
                            </option>
                        }
                    }
                </select>
                <small class="form-text text-muted">Mantén presionado <strong>Ctrl</strong> (Windows) o <strong>Cmd</strong> (Mac) para seleccionar o deseleccionar varios ingredientes.</small>
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Cambiar Foto (Opcional)</label>
                <input type="file" name="archivo_foto" class="form-control" accept="image/*" />
                @if (!string.IsNullOrEmpty(Model.Foto))
                {
                    <div class="mt-2">
                        <img src="@Model.Foto" width="120" class="img-thumbnail" />
                    </div>
                }
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Guardar Cambios" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
