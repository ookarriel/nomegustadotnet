@model IEnumerable<SistemaManejoBar.Models.Ingrediente>
@{
    ViewData["Title"] = "Inventario de Ingredientes";
    bool esEditor = User.IsInRole("Administrador") || User.IsInRole("Supervisor");
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="fw-bold text-dark">Inventario de Ingredientes</h1>
        @if (esEditor)
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-circle"></i> Agregar Ingrediente</a>
        }
    </div>

    <!-- Alertas de estado -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3 border-0 shadow-sm" role="alert">
            <strong>¡Atención!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3 border-0 shadow-sm" role="alert">
            <strong>¡Excelente!</strong> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Barra de búsqueda e interactividad -->
    <div class="card shadow-sm border-0 rounded-3 mb-4 p-3 bg-light">
        <form method="get" asp-action="Index" class="row g-2 align-items-center">
            <input type="hidden" name="orden" value="@ViewData["OrdenActual"]" />
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" name="buscar" value="@ViewData["BuscarActual"]" class="form-control" placeholder="Buscar por nombre, tipo o unidad..." />
                    <button type="submit" class="btn btn-primary">Buscar</button>
                </div>
            </div>
            <div class="col-md-4">
                @if (!string.IsNullOrEmpty(ViewData["BuscarActual"]?.ToString()))
                {
                    <a asp-action="Index" asp-route-orden="@ViewData["OrdenActual"]" class="btn btn-outline-secondary">Limpiar Búsqueda</a>
                }
            </div>
        </form>
    </div>

    <!-- Resumen de resultados -->
    <div class="mb-2 text-muted small">
        Mostrando @ViewData["RegistroInicio"]–@ViewData["RegistroFin"] de @ViewData["TotalRegistros"] resultados
    </div>

    <!-- Tabla interactiva -->
    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="cursor: pointer;">
                            <a asp-action="Index" asp-route-buscar="@ViewData["BuscarActual"]" asp-route-orden="@ViewData["NombreSortParam"]" class="text-white text-decoration-none">
                                Ingrediente 
                                @(ViewData["OrdenActual"]?.ToString() == "nombre_desc" ? "▼" : (string.IsNullOrEmpty(ViewData["OrdenActual"]?.ToString()) ? "▲" : ""))
                            </a>
                        </th>
                        <th style="cursor: pointer;">
                            <a asp-action="Index" asp-route-buscar="@ViewData["BuscarActual"]" asp-route-orden="@ViewData["StockSortParam"]" class="text-white text-decoration-none">
                                Stock 
                                @(ViewData["OrdenActual"]?.ToString() == "stock_asc" ? "▲" : (ViewData["OrdenActual"]?.ToString() == "stock_desc" ? "▼" : ""))
                            </a>
                        </th>
                        <th>Unidad de Medida</th>
                        <th style="cursor: pointer;">
                            <a asp-action="Index" asp-route-buscar="@ViewData["BuscarActual"]" asp-route-orden="@ViewData["TipoSortParam"]" class="text-white text-decoration-none">
                                Tipo de Ingrediente 
                                @(ViewData["OrdenActual"]?.ToString() == "tipo_asc" ? "▲" : (ViewData["OrdenActual"]?.ToString() == "tipo_desc" ? "▼" : ""))
                            </a>
                        </th>
                        @if (esEditor)
                        {
                            <th class="text-end px-4">Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No se encontraron ingredientes registrados.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold text-dark">
                                    @Html.DisplayFor(modelItem => item.NombreIngrediente)
                                </td>
                                <td>
                                    <span class="badge @(item.Stock < 5 ? "bg-danger" : "bg-success")">
                                        @Html.DisplayFor(modelItem => item.Stock)
                                    </span>
                                </td>
                                <td class="text-muted small">
                                    @Html.DisplayFor(modelItem => item.Unidad)
                                </td>
                                <td>
                                    <span class="badge bg-secondary">
                                        @Html.DisplayFor(modelItem => item.IdTipoIngredienteNavigation.NombreTipoIngrediente)
                                    </span>
                                </td>
                                @if (esEditor)
                                {
                                    <td class="text-end px-4">
                                        <div class="d-inline-flex gap-2">
                                            <a asp-action="Edit" asp-route-id="@item.IdIngrediente" class="btn btn-outline-warning btn-sm rounded-2">Editar</a>
                                            <form asp-action="Delete" asp-route-id="@item.IdIngrediente" method="post" class="d-inline" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este ingrediente? Se quitará de todas las recetas.');">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-2">Eliminar</button>
                                            </form>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (Convert.ToInt32(ViewData["TotalPaginas"]) > 1)
    {
        <div class="d-flex justify-content-center mt-4">
            <nav aria-label="Navegación de páginas">
                <ul class="pagination shadow-sm">
                    <li class="page-item @(Convert.ToInt32(ViewData["PaginaActual"]) == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["BuscarActual"]" asp-route-orden="@ViewData["OrdenActual"]" asp-route-pagina="@(Convert.ToInt32(ViewData["PaginaActual"]) - 1)">Anterior</a>
                    </li>
                    @for (int i = 1; i <= Convert.ToInt32(ViewData["TotalPaginas"]); i++)
                    {
                        <li class="page-item @(i == Convert.ToInt32(ViewData["PaginaActual"]) ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["BuscarActual"]" asp-route-orden="@ViewData["OrdenActual"]" asp-route-pagina="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Convert.ToInt32(ViewData["PaginaActual"]) == Convert.ToInt32(ViewData["TotalPaginas"]) ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-buscar="@ViewData["BuscarActual"]" asp-route-orden="@ViewData["OrdenActual"]" asp-route-pagina="@(Convert.ToInt32(ViewData["PaginaActual"]) + 1)">Siguiente</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
