@model SistemaManejoBar.Models.Ingrediente

@{
    ViewData["Title"] = "Create";
}

<h1>Agregar</h1>
<h4>Ingrediente</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label class="control-label">Nombre del Ingrediente</label>
                <input asp-for="NombreIngrediente" class="form-control" />
                <span asp-validation-for="NombreIngrediente" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Stock</label>
                <input asp-for="Stock" class="form-control" type="number" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Unidad</label>
                <input asp-for="Unidad" class="form-control" />
                <span asp-validation-for="Unidad" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Tipo de Ingrediente</label>
                <select asp-for="IdTipoIngrediente" class="form-control" asp-items="ViewBag.IdTipoIngrediente"></select>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Crear Ingrediente" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
