@model SistemaManejoBar.Models.RegisterViewModel
@{
    ViewData["Title"] = "Registrarse";
}

<div class="row justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="col-md-6 col-lg-5">
        <!-- Tarjeta de Registro con diseño premium y limpio -->
        <div class="card shadow-lg border-0 rounded-4" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
            <div class="card-body p-4 p-sm-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-dark mb-1">Crea tu Cuenta</h2>
                    <p class="text-muted small">Regístrate para comenzar a gestionar el dossier de coctelería</p>
                </div>

                <form asp-controller="Account" asp-action="Register" method="post" class="needs-validation">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 small mb-3 py-2" role="alert"></div>

                    <!-- Input Nombre Completo -->
                    <div class="form-floating mb-3">
                        <input asp-for="NombreCompleto" class="form-control rounded-3" placeholder="Juan Pérez" id="floatingNombre" />
                        <label asp-for="NombreCompleto" for="floatingNombre">Nombre Completo</label>
                        <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                    </div>

                    <!-- Input Correo -->
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control rounded-3" placeholder="nombre@ejemplo.com" id="floatingEmail" />
                        <label asp-for="Email" for="floatingEmail">Correo electrónico</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- Input Contraseña -->
                    <div class="form-floating mb-3">
                        <input asp-for="Password" class="form-control rounded-3" placeholder="Contraseña" id="floatingPassword" />
                        <label asp-for="Password" for="floatingPassword">Contraseña</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                        <div class="form-text text-muted small mt-1">
                            Debe tener al menos 8 caracteres, incluir mayúscula, número y un carácter especial.
                        </div>
                    </div>

                    <!-- Input Confirmar Contraseña -->
                    <div class="form-floating mb-4">
                        <input asp-for="ConfirmPassword" class="form-control rounded-3" placeholder="Confirmar Contraseña" id="floatingConfirmPassword" />
                        <label asp-for="ConfirmPassword" for="floatingConfirmPassword">Confirmar Contraseña</label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <!-- Botón Registrarse -->
                    <button class="btn btn-success btn-lg w-100 rounded-3 mb-3 fw-semibold shadow-sm transition-all" type="submit">
                        Registrarse
                    </button>
                </form>

                <div class="text-center mt-3">
                    <p class="text-muted small mb-0">¿Ya tienes cuenta? <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-bold text-success">Inicia sesión</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
