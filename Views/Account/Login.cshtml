@model SistemaManejoBar.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="row justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="col-md-5 col-lg-4">
        <!-- Tarjeta de login con diseño moderno y premium (Glassmorphism) -->
        <div class="card shadow-lg border-0 rounded-4" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
            <div class="card-body p-4 p-sm-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-dark mb-1">¡Bienvenido de nuevo!</h2>
                    <p class="text-muted small">Ingresa tus credenciales para acceder al sistema de bar</p>
                </div>

                <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="needs-validation">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 small mb-3 py-2" role="alert"></div>

                    <!-- Input Correo -->
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control rounded-3" placeholder="nombre@ejemplo.com" id="floatingInput" />
                        <label asp-for="Email" for="floatingInput">Correo electrónico</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- Input Contraseña -->
                    <div class="form-floating mb-3">
                        <input asp-for="Password" class="form-control rounded-3" placeholder="Contraseña" id="floatingPassword" />
                        <label asp-for="Password" for="floatingPassword">Contraseña</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <!-- Recuérdame -->
                    <div class="form-check mb-4 text-start">
                        <input class="form-check-input" type="checkbox" asp-for="RememberMe" id="rememberMeCheck">
                        <label class="form-check-label text-muted small" for="rememberMeCheck">
                            @Html.DisplayNameFor(m => m.RememberMe)
                        </label>
                    </div>

                    <!-- Botón Ingresar -->
                    <button class="btn btn-primary btn-lg w-100 rounded-3 mb-3 fw-semibold shadow-sm transition-all" type="submit">
                        Iniciar Sesión
                    </button>
                </form>

                <div class="text-center mt-3">
                    <p class="text-muted small mb-0">¿No tienes cuenta? <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold text-primary">Regístrate aquí</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
