@using Microsoft.AspNetCore.Identity
@using SistemaManejoBar.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var appUser = await UserManager.GetUserAsync(User);
        var nombreMostrar = appUser?.NombreCompleto ?? User.Identity?.Name;
        <li class="nav-item">
            <span class="nav-link text-dark font-weight-bold">Hola, @nombreMostrar!</span>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="nav-link btn btn-link text-dark border-0 bg-transparent">Cerrar Sesión</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Registrarse</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Iniciar Sesión</a>
        </li>
    }
</ul>